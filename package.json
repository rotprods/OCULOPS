{
  "name": "oculops",
  "private": true,
  "version": "10.0.0",
  "description": "OCULOPS — Autonomous Growth Operating System with AI agents, market intelligence, and pipeline automation",
  "author": "Roberto Ortega",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "preview": "vite preview",
    "protect:check": "node scripts/protected-files-check.mjs",
    "deploy:gate": "node scripts/deploy-gate.mjs",
    "context:audit": "node scripts/context-audit.mjs",
    "context:audit:json": "node scripts/context-audit.mjs --json",
    "n8n:repair": "node scripts/repair-n8n.mjs --local --live --export-live",
    "n8n:repair:local": "node scripts/repair-n8n.mjs --local",
    "n8n:repair:live": "node scripts/repair-n8n.mjs --live --export-live",
    "gws": "node scripts/gws.mjs",
    "gws:auth:setup": "node scripts/gws.mjs auth setup",
    "gws:auth:login": "node scripts/gws.mjs auth login",
    "gws:drive:recent": "node scripts/gws.mjs drive files list --params {\"pageSize\":10}",
    "gitnexus:build": "npm --prefix ../github-repos/GitNexus/gitnexus run build",
    "gitnexus:index": "node scripts/gitnexus.mjs analyze .",
    "gitnexus:index:force": "node scripts/gitnexus.mjs analyze . --force",
    "gitnexus:index:embeddings": "node scripts/gitnexus.mjs analyze . --embeddings",
    "gitnexus:status": "node scripts/gitnexus.mjs status",
    "gitnexus:clean": "node scripts/gitnexus.mjs clean --force",
    "gitnexus:mcp": "node scripts/gitnexus.mjs mcp",
    "gitnexus:serve": "node scripts/gitnexus.mjs serve",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@sentry/react": "^10.43.0",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.35.2",
    "leaflet": "^1.9.4",
    "posthog-js": "^1.360.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.6.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "puppeteer": "^24.39.0",
    "supabase": "^2.77.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.oculops.app",
    "productName": "OCULOPS",
    "mac": {
      "category": "public.app-category.business",
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
