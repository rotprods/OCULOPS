{
  "name": "oculops",
  "private": true,
  "version": "10.0.0",
  "description": "OCULOPS — Autonomous Growth Operating System with AI agents, market intelligence, and pipeline automation",
  "author": "Roberto Ortega",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "preview": "vite preview",
    "protect:check": "node scripts/protected-files-check.mjs",
    "deploy:gate": "node scripts/deploy-gate.mjs",
    "context:audit": "node scripts/context-audit.mjs",
    "context:audit:json": "node scripts/context-audit.mjs --json",
    "n8n:repair": "node scripts/repair-n8n.mjs --local --live --export-live",
    "n8n:repair:local": "node scripts/repair-n8n.mjs --local",
    "n8n:repair:live": "node scripts/repair-n8n.mjs --live --export-live",
    "sync:n8n-templates": "node scripts/sync-n8n-templates.mjs",
    "audit:n8n-workflows": "node scripts/audit-n8n-workflows.mjs",
    "bootstrap:n8n-credentials": "node scripts/bootstrap-n8n-credentials.mjs",
    "reconcile:n8n-oculops": "node scripts/reconcile-n8n-oculops.mjs",
    "n8n:bridge:cloudflare": "node scripts/open-n8n-cloudflare-bridge.mjs",
    "n8n:bridge:cloudflare:down": "node scripts/close-n8n-cloudflare-bridge.mjs",
    "cutover:mac": "bash scripts/finalize-mac-cutover.sh --with-n8n-bridge",
    "inject:n8n-api-context": "node scripts/inject-api-context-automation-bridges.mjs",
    "n8n:install-template": "node scripts/install-n8n-template.mjs",
    "gws": "node scripts/gws.mjs",
    "gws:auth:setup": "node scripts/gws.mjs auth setup",
    "gws:auth:login": "node scripts/gws.mjs auth login",
    "gws:bootstrap:gmail": "node scripts/bootstrap-gmail-from-gws.mjs",
    "gws:drive:recent": "node scripts/gws.mjs drive files list --params {\"pageSize\":10}",
    "gitnexus:build": "npm --prefix ../github-repos/GitNexus/gitnexus run build",
    "gitnexus:index": "node scripts/gitnexus.mjs analyze .",
    "gitnexus:index:force": "node scripts/gitnexus.mjs analyze . --force",
    "gitnexus:index:embeddings": "node scripts/gitnexus.mjs analyze . --embeddings",
    "gitnexus:status": "node scripts/gitnexus.mjs status",
    "gitnexus:clean": "node scripts/gitnexus.mjs clean --force",
    "gitnexus:mcp": "node scripts/gitnexus.mjs mcp",
    "gitnexus:serve": "node scripts/gitnexus.mjs serve",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron .",
    "test:e2e": "playwright test",
    "smoke:agentic-core": "node scripts/smoke-agentic-core.mjs",
    "smoke:control-plane": "node scripts/smoke-control-plane.mjs",
    "smoke:control-plane:v2": "node scripts/smoke-control-plane-v2.mjs",
    "test:control-plane:v2": "vitest run --passWithNoTests src/test/variableRuntimeV2.test.js src/test/controlPlaneV2.integration.test.js src/test/controlPlaneV2.performance.test.js",
    "bench:control-plane:v2": "vitest run --passWithNoTests src/test/controlPlaneV2.performance.test.js",
    "control-tower:update": "node scripts/update-control-tower.mjs",
    "readiness:generate": "node scripts/generate-ecosystem-readiness.mjs",
    "readiness:check": "node scripts/check-ecosystem-readiness-gate.mjs",
    "readiness:check:production": "node scripts/check-ecosystem-readiness-gate.mjs --mode production",
    "readiness:check:production:strict": "node scripts/check-ecosystem-readiness-gate.mjs --mode production --production-strict-all-connected true",
    "readiness:gate": "npm run readiness:generate && npm run readiness:check",
    "readiness:gate:production": "npm run readiness:generate && npm run readiness:check:production",
    "readiness:gate:production:strict": "npm run readiness:generate && npm run readiness:check:production:strict",
    "design:factory": "node scripts/design-factory.mjs",
    "design:factory:images": "node scripts/design-factory.mjs --only images",
    "design:factory:code": "node scripts/design-factory.mjs --only code",
    "design:factory:screen": "node scripts/design-factory.mjs --screen",
    "design:factory:list": "node scripts/design-factory.mjs --list",
    "design:factory:py": "python3 scripts/design-factory.py",
    "design:factory:py:screen": "python3 scripts/design-factory.py --screen",
    "sync:public-apis": "node scripts/sync-public-apis.mjs",
    "public-apis:bootstrap": "node scripts/bootstrap-public-api-connectors.mjs",
    "public-apis:finalize": "node scripts/finalize-public-api-infra.mjs",
    "build:public-api-infra-layer": "node scripts/build-public-api-infra-layer.mjs",
    "build:public-api-ecosystem-layer": "node scripts/build-public-api-ecosystem-layer.mjs",
    "build:project-apis": "node scripts/build-project-apis.mjs",
    "smoke:public-connectors": "node scripts/smoke-public-connectors.mjs",
    "smoke:project-apis-bridge": "node scripts/smoke-project-apis-n8n-bridge.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@sentry/react": "^10.43.0",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.35.2",
    "leaflet": "^1.9.4",
    "posthog-js": "^1.360.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.6.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "puppeteer": "^24.39.0",
    "supabase": "^2.77.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.oculops.app",
    "productName": "OCULOPS",
    "mac": {
      "category": "public.app-category.business",
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
